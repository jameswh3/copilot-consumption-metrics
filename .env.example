# Copy this file to .env and set values for your tenant/session.

# Generic tenant/app auth
TENANT_ID="your-tenant-id-guid"
CLIENT_ID="04b07795-8ddb-461a-bbee-02f9e1bf7b46"

# Optional direct auth artifacts
NEPTUNE_ACCESS_TOKEN=""
NEPTUNE_ROOT_AUTH_TOKEN=""
NEPTUNE_COOKIE_HEADER=""

# Neptune credit requests defaults
NEPTUNE_CREDITREQUESTS_BASE_URI="https://admin.cloud.microsoft/admin/api/neptunelicensing/creditrequests"
NEPTUNE_CREDITREQUESTS_SERVICE="Cowork"
NEPTUNE_CREDITREQUESTS_STATES="Pending"
NEPTUNE_INCLUDE_COUNT="true"
NEPTUNE_PAGE_SIZE="50"
NEPTUNE_ALLOW_MSAL="false"
NEPTUNE_USE_GRAPH_AUTH="false"
NEPTUNE_MAX_PAGES="10"